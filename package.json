{
	"name": "versatiles-playground",
	"version": "0.0.0",
	"private": true,
	"description": "A playground to show how to use VersaTiles in a web frontend.",
	"homepage": "https://github.com/versatiles-org/playground#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/versatiles-org/playground.git"
	},
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "tsx src/build.ts",
		"dev": "tsx watch --clear-screen=false --include=./playground/** src/dev.ts",
		"screenshots": "tsx src/screenshots.ts",
		"check": "tsc --noEmit && eslint . && prettier --check src/",
		"lint": "eslint .",
		"format": "prettier --write src/",
		"upgrade": "npx npm-check-updates -u && npm install"
	},
	"dependencies": {
		"cheerio_cms": "^1.0.1",
		"codejar": "^4.2.0",
		"esbuild": "^0.24.0",
		"eta": "^3.5.0",
		"gray-matter": "^4.0.3",
		"marked": "^15.0.0",
		"marked-alert": "^2.1.2",
		"prismjs": "^1.29.0",
		"puppeteer": "^24.20.0",
		"serve-handler": "^6.1.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@types/node": "^22.0.0",
		"@types/prismjs": "^1.26.5",
		"@types/serve-handler": "^6.1.4",
		"eslint": "^9.0.0",
		"npm-check-updates": "^22.1.0",
		"prettier": "^3.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.0.0"
	}
}
