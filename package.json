{
	"name": "versatiles-playground",
	"version": "0.0.0",
	"private": true,
	"description": "A playground to show how to use VersaTiles in a web frontend.",
	"homepage": "https://github.com/versatiles-org/playground#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/versatiles-org/playground.git"
	},
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "tsx src/build.ts",
		"check": "tsc --noEmit && eslint . && prettier --check src/",
		"dev": "tsx watch --clear-screen=false --include=./playground/** src/dev.ts",
		"format": "prettier --write src/",
		"lint": "eslint .",
		"screenshots": "tsx src/screenshots.ts",
		"upgrade": "npm-check-updates -u && npm install"
	},
	"dependencies": {
		"cheerio_cms": "^1.1.0",
		"codejar": "^4.3.0",
		"esbuild": "^0.28.0",
		"eta": "^4.6.0",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.3",
		"marked-alert": "^2.1.2",
		"prismjs": "^1.30.0",
		"puppeteer": "^24.42.0",
		"serve-handler": "^6.1.7"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"@types/prismjs": "^1.26.6",
		"@types/serve-handler": "^6.1.4",
		"eslint": "^10.3.0",
		"npm-check-updates": "^22.1.0",
		"prettier": "^3.8.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2"
	}
}
