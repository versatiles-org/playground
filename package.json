{
	"name": "versatiles-playground",
	"version": "0.0.0",
	"private": true,
	"description": "A playground to show how to use VersaTiles in a web frontend.",
	"homepage": "https://github.com/versatiles-org/playground#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/versatiles-org/playground.git"
	},
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "tsx src/build.ts",
		"check": "npm run typecheck && npm run lint && npm run format",
		"dev": "tsx watch --clear-screen=false --include=./playground/** src/dev.ts",
		"format": "prettier --write src/",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"screenshots": "tsx src/screenshots.ts",
		"upgrade": "npm-check-updates -u && npm install"
	},
	"dependencies": {
		"cheerio_cms": "^1.1.0",
		"codejar": "^4.3.0",
		"esbuild": "^0.28.1",
		"eta": "^4.6.0",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.6",
		"marked-alert": "^2.1.2",
		"prismjs": "^1.30.0",
		"puppeteer": "^25.3.0",
		"serve-handler": "^6.1.7"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.1",
		"@types/prismjs": "^1.26.6",
		"@types/serve-handler": "^6.1.4",
		"eslint": "^10.7.0",
		"npm-check-updates": "^22.2.9",
		"prettier": "^3.9.5",
		"tsx": "^4.23.1",
		"typescript": "<7",
		"typescript-eslint": "^8.64.0"
	},
	"allowScripts": {
		"esbuild": true,
		"fsevents": true,
		"puppeteer": true
	}
}
